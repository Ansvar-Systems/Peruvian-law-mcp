{
  "$schema": "./golden-tests.schema.json",
  "version": "1.1",
  "mcp_name": "Peruvian Law MCP",
  "description": "Golden contract tests for real-ingested Peruvian legal data from Diario Oficial El Peruano",
  "tests": [
    {
      "id": "pe-001",
      "category": "article_retrieval",
      "description": "Retrieve DL 1700 Article 12-A (illicit acquisition/traffic of digital data)",
      "tool": "get_provision",
      "input": {
        "document_id": "pe-dl-1700",
        "section": "12-A"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": [
          "datos informáticos"
        ],
        "fields_present": [
          "content",
          "provision_ref"
        ],
        "text_not_empty": true
      }
    },
    {
      "id": "pe-002",
      "category": "article_retrieval",
      "description": "Retrieve DL 1741 Article 12-A amendment",
      "tool": "get_provision",
      "input": {
        "document_id": "pe-dl-1741",
        "section": "12-A"
      },
      "assertions": {
        "result_not_empty": true,
        "fields_present": [
          "content",
          "provision_ref"
        ],
        "text_not_empty": true
      }
    },
    {
      "id": "pe-003",
      "category": "article_retrieval",
      "description": "Retrieve Reglamento IA 31814 Article 1",
      "tool": "get_provision",
      "input": {
        "document_id": "pe-ds-reglamento-ia-31814",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "fields_present": [
          "content",
          "provision_ref"
        ],
        "text_not_empty": true
      }
    },
    {
      "id": "pe-004",
      "category": "search",
      "description": "FTS search for 'datos' returns relevant provisions",
      "tool": "search_legislation",
      "input": {
        "query": "datos"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1
      }
    },
    {
      "id": "pe-005",
      "category": "search",
      "description": "FTS search for 'seguridad digital' returns relevant provisions",
      "tool": "search_legislation",
      "input": {
        "query": "\"seguridad digital\""
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1
      }
    },
    {
      "id": "pe-006",
      "category": "search",
      "description": "FTS search for 'inteligencia artificial' returns IA regulation references",
      "tool": "search_legislation",
      "input": {
        "query": "\"inteligencia artificial\""
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1
      }
    },
    {
      "id": "pe-007",
      "category": "citation_roundtrip",
      "description": "Provision retrieval returns non-empty citation-capable context",
      "tool": "get_provision",
      "input": {
        "document_id": "pe-dl-1700",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "text_not_empty": true
      }
    },
    {
      "id": "pe-008",
      "category": "metadata",
      "description": "list_sources returns Peruvian jurisdiction metadata",
      "tool": "list_sources",
      "input": {},
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": [
          "PE",
          "Peru",
          "Peruvian"
        ]
      }
    },
    {
      "id": "pe-010",
      "category": "negative_test",
      "description": "Non-existent law returns graceful empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "fictional-law-2099",
        "section": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "pe-011",
      "category": "negative_test",
      "description": "Malformed section returns graceful empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "pe-dl-1700",
        "section": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "pe-012",
      "category": "list_sources",
      "description": "list_sources returns source provenance including El Peruano",
      "tool": "list_sources",
      "input": {},
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": [
          "El Peruano",
          "busquedas.elperuano.pe"
        ]
      }
    }
  ]
}
